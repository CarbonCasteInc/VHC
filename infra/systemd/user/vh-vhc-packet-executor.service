[Unit]
Description=VHC incident packet pull executor
Documentation=file:/home/humble/VHC/docs/ops/vhc-incident-response.md

[Service]
Type=oneshot
TimeoutStartSec=180
Environment=VHC_REPO=/home/humble/VHC
Environment=PATH=/home/humble/.local/bin:/home/humble/.hermes/node/bin:/usr/local/bin:/usr/bin:/bin
WorkingDirectory=/home/humble/VHC
ExecStart=/usr/bin/env bash -c 'if [ -f "%h/.config/vhc/incident-executor.env" ]; then set -a; source "%h/.config/vhc/incident-executor.env"; set +a; fi; exec node "/home/humble/VHC/tools/scripts/vhc-packet-executor.mjs" --packet "%h/.local/state/vhc/incident-executor/pending-packet.json" --review "%h/.local/state/vhc/incident-executor/pending-review.json" --approval "%h/.local/state/vhc/incident-executor/pending-approval.json" --review-public-key "%h/.config/vhc/incident-review-public-key.pem" --systemctl "%h/.local/state/vhc/incident-executor/publisher-systemctl.json"'
