# VHC StoryCluster production env template.
# Keep the real file outside git at ~/.config/vhc/storycluster.env with mode 600.
# Do not commit real secrets.

# The service is local-only. The publisher uses the matching remote URL/token in
# ~/.config/vhc/news-aggregator.env.
VH_STORYCLUSTER_SERVER_HOST=127.0.0.1
VH_STORYCLUSTER_SERVER_PORT=4310
VH_STORYCLUSTER_SERVER_AUTH_TOKEN=<from-storycluster-public-beta-auth-token-v1.txt>
VH_STORYCLUSTER_STATE_DIR=/home/humble/.local/state/vhc/storycluster-engine

# StoryCluster production mode requires Qdrant. Do not set this to memory for
# public-beta production service starts.
NODE_ENV=production
VH_STORYCLUSTER_VECTOR_BACKEND=qdrant
VH_STORYCLUSTER_QDRANT_URL=http://127.0.0.1:6333
VH_STORYCLUSTER_QDRANT_COLLECTION=storycluster_coarse_vectors
VH_STORYCLUSTER_QDRANT_TIMEOUT_MS=20000
VH_STORYCLUSTER_QDRANT_STARTUP_TIMEOUT_MS=120000

# Managed local Qdrant container.
VH_STORYCLUSTER_QDRANT_IMAGE=qdrant/qdrant:v1.13.6
VH_STORYCLUSTER_QDRANT_CONTAINER=vh-storycluster-qdrant
VH_STORYCLUSTER_QDRANT_STORAGE_DIR=/home/humble/.local/state/vhc/storycluster-qdrant/storage
VH_STORYCLUSTER_QDRANT_HTTP_PORT=6333
VH_STORYCLUSTER_QDRANT_GRPC_PORT=6334

# OpenAI provider used by StoryCluster.
OPENAI_API_KEY=<from-storycluster-openai.env>
VH_STORYCLUSTER_TEXT_MODEL=gpt-4o-mini
VH_STORYCLUSTER_OPENAI_TIMEOUT_MS=120000
VH_STORYCLUSTER_OPENAI_PREFLIGHT_TIMEOUT_MS=120000
