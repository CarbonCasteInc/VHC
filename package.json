{
  "name": "vh-monorepo",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "prebuild:guards": "pnpm --dir tools/scripts/vh exec tsx ../guards/checkProductionFlags.ts",
    "build": "pnpm -r --workspace-root=false build",
    "typecheck": "pnpm -r --workspace-root=false typecheck",
    "test": "pnpm -r --workspace-root=false test",
    "lint": "pnpm -r --workspace-root=false lint",
    "vh": "pnpm --filter \"@vh/cli\" exec tsx src/index.ts",
    "test:quick": "vitest run",
    "test:storycluster:quality": "pnpm --filter @vh/storycluster-engine exec vitest run src/vectorBackend.test.ts src/server.test.ts src/stageRunner.pipeline.test.ts src/coherenceAudit.test.ts src/storyclusterQualityGate.test.ts --config ./vitest.config.ts --reporter=verbose",
    "test:storycluster:live-benchmark": "pnpm --filter @vh/storycluster-engine exec vitest run src/liveBenchmark.integration.test.ts --config ./vitest.config.ts --reporter=verbose",
    "test:storycluster:correctness": "pnpm --filter @vh/storycluster-engine exec vitest run src/benchmarkCorpusKnownEventOngoingFixtures.test.ts src/storyclusterKnownEventOngoingReplay.test.ts src/storyclusterQualityGate.test.ts --config ./vitest.config.ts --reporter=verbose && pnpm --filter @vh/e2e test:live:daemon-feed:build && pnpm --filter @vh/e2e test:live:daemon-feed:semantic-gate",
    "check:storycluster:correctness": "node ./packages/e2e/src/live/storycluster-correctness-gate.mjs",
    "test:storycluster:gates": "pnpm --filter @vh/e2e test:live:daemon-feed:build && pnpm --filter @vh/e2e test:live:daemon-feed:gates",
    "test:storycluster:publisher-canary": "pnpm --filter @vh/e2e test:live:daemon-feed:build && pnpm --filter @vh/e2e test:live:daemon-feed:publisher-canary",
    "test:storycluster:consumer-smoke": "pnpm --filter @vh/e2e test:live:daemon-feed:consumer-smoke",
    "test:storycluster:smoke": "pnpm --filter @vh/e2e test:live:daemon-feed:build && pnpm --filter @vh/e2e test:live:daemon-feed:semantic-soak",
    "test:storycluster:smoke:readiness": "pnpm --filter @vh/e2e test:live:daemon-feed:build && (pnpm --filter @vh/e2e test:live:daemon-feed:semantic-soak || true) && pnpm --filter @vh/e2e test:live:daemon-feed:semantic-soak:readiness",
    "collect:storycluster:headline-soak": "pnpm report:news-sources:health && pnpm test:storycluster:smoke:readiness",
    "report:storycluster:offline-cluster-replay": "pnpm --filter @vh/e2e report:offline-cluster-replay",
    "report:storycluster:production-readiness": "pnpm --filter @vh/e2e report:live:daemon-feed:production-readiness",
    "check:storycluster:production-readiness": "pnpm check:storycluster:correctness && pnpm check:news-sources:health && VH_STORYCLUSTER_PRODUCTION_READINESS_ENFORCE=true pnpm report:storycluster:production-readiness",
    "report:news-sources:admission": "pnpm --filter @vh/news-aggregator report:source-admission",
    "report:news-sources:health": "NODE_OPTIONS=--max-old-space-size=4096 pnpm --filter @vh/news-aggregator report:source-health",
    "scout:news-sources:candidates": "NODE_OPTIONS=--max-old-space-size=4096 pnpm --filter @vh/news-aggregator report:source-scout",
    "check:news-sources:health": "NODE_OPTIONS=--max-old-space-size=4096 pnpm --filter @vh/news-aggregator check:source-health",
    "live:stack:up": "bash tools/scripts/live-local-stack.sh up",
    "live:stack:up:public": "VH_LOCAL_STACK_FEED_MODE=public bash tools/scripts/live-local-stack.sh up",
    "live:stack:up:validated-snapshot": "VH_LOCAL_STACK_FEED_MODE=validated-snapshot bash tools/scripts/live-local-stack.sh up",
    "live:stack:status": "bash tools/scripts/live-local-stack.sh status",
    "live:stack:down": "bash tools/scripts/live-local-stack.sh down",
    "live:smoke": "bash tools/scripts/live-local-stack.sh smoke",
    "automation:ensure-stack": "bash tools/scripts/automation-stack.sh ensure",
    "automation:stack:health": "bash tools/scripts/automation-stack.sh status",
    "automation:stack:restart": "bash tools/scripts/automation-stack.sh restart",
    "automation:stack:stop": "bash tools/scripts/automation-stack.sh stop",
    "automation:stack:install-launchd": "bash tools/scripts/install-automation-stack-launchd.sh install",
    "automation:stack:uninstall": "bash tools/scripts/install-automation-stack-launchd.sh uninstall",
    "automation:test:storycluster:publisher-canary": "pnpm automation:ensure-stack && pnpm automation:stack:health && VH_DAEMON_FEED_REQUIRE_SHARED_STACK=true pnpm test:storycluster:publisher-canary",
    "automation:test:storycluster:consumer-smoke": "pnpm automation:ensure-stack && pnpm automation:stack:health && VH_DAEMON_FEED_REQUIRE_SHARED_STACK=true VH_DAEMON_FEED_CONSUMER_SMOKE_HTTP_ONLY=true pnpm test:storycluster:consumer-smoke",
    "report:storycluster:fixture-candidate-intake": "pnpm --filter @vh/e2e report:live:daemon-feed:fixture-candidate-intake",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm --filter @vh/e2e test",
    "test:workflow": "act -j build-and-test",
    "deps:check": "madge --circular --extensions ts,tsx .",
    "docs:check": "node tools/scripts/check-docs-governance.mjs",
    "lint:loc": "./tools/scripts/check-loc.sh",
    "bundle:check": "node tools/scripts/check-bundle-size.mjs",
    "hooks:install": "bash tools/scripts/install-git-hooks.sh"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "20.17.19",
      "tinypool": "1.0.2"
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.4",
    "jsdom": "^24.1.3",
    "madge": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@9.7.1+sha512.faf344af2d6ca65c4c5c8c2224ea77a81a5e8859cbc4e06b1511ddce2f0151512431dd19e6aff31f2c6a8f5f2aced9bd2273e1fed7dd4de1868984059d2c4247"
}
